@model IEnumerable<DATN_StudentMangement.Models.Monhoc>
@{
    ViewBag.Title = "Quản lí môn học";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<div class="card-custom">
    @if (TempData["ThongBao"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" id="thongBaoHeThong">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["ThongBao"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" id="loiHeThong">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0 text-uppercase">Danh sách môn học</h4>
        <div>
            @using (Html.BeginForm("ImportExcel", "MonHoc", FormMethod.Post, new { enctype = "multipart/form-data", @class = "d-inline-block me-2" }))
            {
                <input type="file" name="fileExcel" id="fileExcel" style="display: none;" accept=".xlsx, .xls" onchange="this.form.submit()" />
                <button type="button" class="btn btn-success" onclick="document.getElementById('fileExcel').click()">
                    <i class="fa-solid fa-file-excel"></i> Nhập từ Excel
                </button>
            }
            <button type="button" class="btn btn-info text-white ms-1 me-2" onclick="window.location.href='@Url.Action("XuatExcel", "MonHoc")'">
                <i class="fa-solid fa-file-export"></i> Xuất Excel
            </button>
            <button class="btn btn-primary" onclick="moFormThem()">
                <i class="fa-solid fa-plus"></i> Thêm môn học
            </button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle" id="bangMonHoc" style="width:100%">
            <thead class="table-light text-center">
                <tr><th>Mã MH</th><th>Tên môn học</th><th>Số TC</th><th>Tỷ lệ TX1 (%)</th><th>Tỷ lệ TX2 (%)</th><th>Tỷ lệ Thi (%)</th><th>Thao tác</th></tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.MaMH</td>
                            <td>@item.TenMH</td>
                            <td class="text-center">@item.SoTinChi</td>
                            <td class="text-center text-primary">@item.TyLeTX1</td>
                            <td class="text-center text-primary">@item.TyLeTX2</td>
                            <td class="text-center text-danger fw-bold">@item.TyLeThi</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning" onclick="moFormSua('@item.MaMH', '@item.TenMH', '@item.SoTinChi', '@item.TyLeTX1', '@item.TyLeTX2', '@item.TyLeThi')"><i class="fa-solid fa-pen-to-square"></i></button>
                                <a href="@Url.Action("Xoa", "MonHoc", new { id = item.MaMH })" class="btn btn-sm btn-danger ms-1" onclick="return confirm('Xác nhận xóa môn học?');"><i class="fa-solid fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="monHocModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("LuuThongTin", "MonHoc", FormMethod.Post))
            {
                <div class="modal-header bg-light">
                    <h5 class="modal-title" id="modalTitle">Thêm môn học</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row">
                    <div class="col-md-12 mb-3"><label class="form-label">Mã môn học</label><input type="text" class="form-control bg-light" id="MaMH" name="MaMH" readonly></div>
                    <div class="col-md-8 mb-3"><label class="form-label">Tên môn học</label><input type="text" class="form-control" id="TenMH" name="TenMH" required></div>
                    <div class="col-md-4 mb-3"><label class="form-label">Số tín chỉ</label><input type="number" class="form-control" id="SoTinChi" name="SoTinChi" min="1" required></div>
                    <div class="col-md-4 mb-3"><label class="form-label">Tỷ lệ TX1 (%)</label><input type="number" class="form-control" id="TyLeTX1" name="TyLeTX1" value="15" required></div>
                    <div class="col-md-4 mb-3"><label class="form-label">Tỷ lệ TX2 (%)</label><input type="number" class="form-control" id="TyLeTX2" name="TyLeTX2" value="15" required></div>
                    <div class="col-md-4 mb-3"><label class="form-label">Tỷ lệ Thi (%)</label><input type="number" class="form-control" id="TyLeThi" name="TyLeThi" value="70" required></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button><button type="submit" class="btn btn-primary">Lưu</button></div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#bangMonHoc').DataTable({
                "language": {
                    "sProcessing": "Đang xử lý...",
                    "sLengthMenu": "Hiển thị _MENU_ mục",
                    "sZeroRecords": "Không tìm thấy dòng nào phù hợp",
                    "sInfo": "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
                    "sInfoEmpty": "Đang xem 0 đến 0 trong tổng số 0 mục",
                    "sInfoFiltered": "(được lọc từ _MAX_ mục)",
                    "sInfoPostFix": "",
                    "sSearch": "Tìm kiếm:",
                    "sUrl": "",
                    "oPaginate": {
                        "sFirst": "Đầu",
                        "sPrevious": "Trước",
                        "sNext": "Tiếp",
                        "sLast": "Cuối"
                    },
                    "oAria": {
                        "sSortAscending": ": Kích hoạt để sắp xếp cột tăng dần",
                        "sSortDescending": ": Kích hoạt để sắp xếp cột giảm dần"
                    }
                } });

            if ($('#thongBaoHeThong').length > 0) {
                setTimeout(function () {
                    $('#thongBaoHeThong').fadeOut('slow');
                }, 3000);
            }
            if ($('#loiHeThong').length > 0) {
                setTimeout(function () {
                    $('#loiHeThong').fadeOut('slow');
                }, 3000);
            }
        });

        var monHocModal = new bootstrap.Modal(document.getElementById('monHocModal'));

        function moFormThem() {
            document.getElementById('modalTitle').innerText = 'Thêm môn học mới';
            document.getElementById('MaMH').value = '@ViewBag.NextMaMH';
            document.getElementById('TenMH').value = '';
            document.getElementById('SoTinChi').value = '';
            document.getElementById('TyLeTX1').value = '15';
            document.getElementById('TyLeTX2').value = '15';
            document.getElementById('TyLeThi').value = '70';
            monHocModal.show();
        }

        function moFormSua(maMH, tenMH, soTinChi, tx1, tx2, thi) {
            document.getElementById('modalTitle').innerText = 'Cập nhật thông tin môn học';
            document.getElementById('MaMH').value = maMH;
            document.getElementById('TenMH').value = tenMH;
            document.getElementById('SoTinChi').value = soTinChi;
            document.getElementById('TyLeTX1').value = tx1 || '15';
            document.getElementById('TyLeTX2').value = tx2 || '15';
            document.getElementById('TyLeThi').value = thi || '70';
            monHocModal.show();
        }
    </script>
}