<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Quản lí giáo vụ Senikaa</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Thiết lập Sidebar */
        .sidebar {
            width: 250px;
            background-color: #343a40;
            color: #fff;
            display: flex;
            flex-direction: column;
            transition: all 0.3s;
        }

            .sidebar .logo {
                font-size: 1.5rem;
                font-weight: 600;
                text-align: center;
                padding: 20px 0;
                border-bottom: 1px solid #4f5962;
                text-decoration: none;
                color: #fff;
            }

            .sidebar .nav-link {
                color: #c2c7d0;
                padding: 12px 20px;
                border-bottom: 1px solid transparent;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    background-color: #495057;
                    color: #fff;
                    border-left: 4px solid #0d6efd;
                }

                .sidebar .nav-link i {
                    width: 25px;
                    text-align: center;
                    margin-right: 10px;
                }

        /* Thiết lập Main Content */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .top-navbar {
            background-color: #fff;
            padding: 15px 25px;
            border-bottom: 1px solid #dee2e6;
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        .content-body {
            padding: 25px;
            flex: 1;
        }

        .card-custom {
            background-color: #fff;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.05);
            padding: 20px;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <nav class="sidebar">
            <a href="#" class="logo">ĐẠI HỌC SENIKAA</a>
            <div class="nav flex-column mt-3">
                <a href="@Url.Action("Index", "SinhVien")" class="nav-link">
                    <i class="fa-solid fa-users"></i> Quản lí sinh viên
                </a>
                <a href="@Url.Action("Index", "GiangVien")" class="nav-link">
                    <i class="fa-solid fa-chalkboard-user"></i> Quản lí giảng viên
                </a>
                <a href="@Url.Action("Index", "MonHoc")" class="nav-link">
                    <i class="fa-solid fa-book"></i> Quản lí môn học
                </a>
                <a href="@Url.Action("Index", "LopHP")" class="nav-link">
                    <i class="fa-solid fa-layer-group"></i> Quản lí lớp học phần
                </a>
                <a href="@Url.Action("DanhSach", "Diem")" class="nav-link">
                    <i class="fa-solid fa-clipboard-list"></i> Quản lí điểm
                </a>
            </div>
        </nav>

        <div class="main-content">
            <div class="top-navbar">
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fa-solid fa-user-circle"></i> Xin chào, Quản trị viên
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton">
                        <li><a class="dropdown-item" href="@Url.Action("DangXuat", "Admin")">Đăng xuất</a></li>
                    </ul>
                </div>
            </div>

            <div class="content-body">
                <div class="card-custom">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>