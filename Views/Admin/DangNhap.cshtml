@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - Đại học Senikaa</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body, html {
            height: 100%;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            background-color: #f4f6f9;
        }

        .bg-wrapper {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/Content/Images/bg-university.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
        }

        .school-name {
            color: #1e293b;
            font-size: 2.2rem;
            font-weight: 550;
            letter-spacing: 4px;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 35px;
            text-shadow: none;
        }

        .brand-header {
            text-align: center;
            margin-bottom: 25px;
        }

            .brand-header img {
                max-width: 100%;
                height: auto;
            }

        .login-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            padding: 40px 30px;
        }

        .login-title {
            text-align: center;
            color: #333;
            margin-bottom: 5px;
            font-weight: 600;
            font-size: 1.5rem;
        }

        .login-subtitle {
            text-align: center;
            color: #6c757d;
            margin-bottom: 25px;
            font-size: 0.9rem;
        }

        .form-floating > .form-control {
            border-radius: 8px;
        }

        .btn-login {
            background-color: #0d6efd;
            color: #fff;
            border-radius: 8px;
            padding: 12px;
            font-size: 1rem;
            margin-top: 10px;
            transition: all 0.3s;
        }

            .btn-login:hover {
                background-color: #0b5ed7;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>
    <div class="bg-wrapper">
        <div class="login-container">

            <h1 class="school-name">Đại học Senikaa</h1>

            <div class="login-card">
                <div class="login-title">ĐĂNG NHẬP</div>
                <div class="login-subtitle">Dành cho Cán bộ Quản trị hệ thống</div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>@ViewBag.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @using (Html.BeginForm("DangNhap", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-floating mb-4">
                        <input type="text" class="form-control" id="MaAD" name="MaAD" placeholder="Tên đăng nhập" required>
                        <label for="MaAD"><i class="fa-solid fa-user text-secondary me-2"></i>Tên đăng nhập</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input type="password" class="form-control" id="MatkhauAD" name="MatkhauAD" placeholder="Mật khẩu" required>
                        <label for="MatkhauAD"><i class="fa-solid fa-lock text-secondary me-2"></i>Mật khẩu</label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-login w-100">
                        ĐĂNG NHẬP <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
                    </button>
                }
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>